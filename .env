# ============================================================================
#  Moodle Cluster + CubeFS — Environment Variables
# ============================================================================

# ─── Database ──────────────────────────────────────────────────────────────
DB_PASSWORD=dbmoodle123

# ─── Moodle Admin ──────────────────────────────────────────────────────────
MOODLE_ADMIN_PASSWORD=Admin1234!
MOODLE_EMAIL=admin@example.com
MOODLE_SITENAME=MoodleDev

# ─── Site URL (public-facing URL with https://) ───────────────────────────
SITE_URL=https://moodle-cubefs.akbarwibisono.my.id

# ─── Exposed port on the host (Nginx listens here) ────────────────────────
PORT=8082

# ─── Moodle cluster size ──────────────────────────────────────────────────
MOODLE_REPLICAS=3

# ─── CubeFS ────────────────────────────────────────────────────────────────
# Host directory where CubeFS stores its internal data (master, meta, disk)
DATA_DIR=./data

# Host mount point for the CubeFS FUSE volume (shared across all containers)
# The deploy.sh script will create this and make it a shared mount.
MOUNT_POINT=/data/cubefs-mount

# CubeFS volume name and capacity (GB)
CUBEFS_VOL_NAME=moodle
CUBEFS_VOL_CAPACITY=30
